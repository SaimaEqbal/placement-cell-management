# Base URL of the Express + PostgreSQL backend (../server). Vite only exposes
# variables prefixed with VITE_ to client code - see src/api/axiosInstance.ts.
#
# NOTE: the project brief documents http://localhost:3000/api as the backend
# base URL, but server/.env in this repo currently sets PORT=3001. Point this
# at whichever port your backend actually prints on startup
# ("Server listening on port ...") - copy this file to ".env" and edit there,
# .env is not committed.
VITE_API_BASE_URL=http://localhost:3000/api
